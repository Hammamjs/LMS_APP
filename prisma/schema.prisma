generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  username String

  role Role @default(Student)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isVerified Boolean @default(false)

  password String

  emailVerified DateTime?
  refreshToken  String?
  phone         String?

  passwordUpdatedAt DateTime?

  isPasswordCodeVerified Boolean @default(false)

  avatar String?
  bio    String?

  authorCourses Course[]

  enrollments Enrollment[]
}

model Course {
  id String @id @default(uuid())

  title String

  originalPrice Int
  discountPrice Int

  duration Int

  slug String @unique

  subtitle String

  requirements String[]

  whatYouLearn String[]

  language String?

  targetAudience String[]

  description String

  rating Int @default(0)

  purchaseCount Int @default(0)

  image String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  category String

  isDeleted Boolean @default(false)

  instructorId String

  level Level @default(Beginner)

  instructor User @relation(fields: [instructorId], references: [id])

  lessons Lesson[]

  enrollments Enrollment[]

  payments Payment[]

  @@index([slug])
}

model Lesson {
  id          String   @id @default(uuid())
  title       String
  url         String
  order       Int
  rating      Int      @default(0)
  description String
  isFree      Boolean  @default(false)
  courseId    String
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  duration    Int 
  updatedAt   DateTime @updatedAt
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id String @id @default(uuid())

  userId   String
  courseId String

  user User @relation(fields: [userId], references: [id])

  course Course @relation(fields: [courseId], references: [id])

  totalLessonsCount Int

  createdAt DateTime @default(now())

  enrolledAt DateTime @default(now())

  status Status @default(ACTIVE)

  completedLessonsIds String[]

  @@unique([userId, courseId])
}

model Payment {
  id        String          @id @default(uuid())
  userId    String
  amount    Float
  status    PaymenStatus
  courseId  String
  paymentId String
  provider  PaymentProvider @default(BANK)
  createdAt DateTime        @default(now())

  course Course @relation(fields: [courseId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  text      String
  title     String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  isDeleted Boolean  @default(false)
}

enum Role {
  Student
  Instructor
  Admin
}

enum Level {
  Beginner
  Intermediate
  Advanced
}

enum Status {
  ACTIVE
  COMPLETED
  REFUND
}

enum PaymenStatus {
  SUCCESS
  FAILED
  PENDING
}

enum PaymentProvider {
  BANK
  STRIPE
}
